# Managed Switcher backend — environment template.
# Copy to backend/.env and fill in real values. backend/.env is git-ignored.
# Generate the key material with:  node cli.js keygen   (prints ready-to-paste values)
# NOTE: all values below are placeholders / illustrative only — never commit real secrets.
#
# *** TWO WARNINGS THAT WILL BREAK A DEPLOY IF MISSED ***
# 1. ALLOWED_HOSTS must include the deployed hostname (Render's *.onrender.com
#    domain, your Vercel domain, or a custom domain) — otherwise EVERY request,
#    including the platform's own health check against GET /health, gets 403
#    "Unexpected Host header." This is checked before anything else runs
#    (lib/httpsec.js's Host-allowlist / DNS-rebinding guard).
# 2. HOST must be set to 0.0.0.0 in the DEPLOYED SERVICE'S environment (Render
#    dashboard / process manager), not just in this file. HOST bypasses the
#    backend/.env merge — server.js reads process.env.HOST directly — so it is
#    only honored when set as a real environment variable on the host. Leaving
#    it unset binds to 127.0.0.1 only, which a platform load balancer cannot
#    reach.

# --- MongoDB (backend-only; the client never sees this) ---
# LOCAL DEV (recommended for now): run a local mongod and point at it:
MONGODB_URI=mongodb://127.0.0.1:27017
# PRODUCTION (Atlas): use the SRV connection string instead:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=switcher

# MONGODB_PRUNE_URI (optional): a SEPARATE connection string for the retention
# prune job (node cli.js maintain / the in-process scheduler), authenticated as
# a DIFFERENT, more-privileged Mongo role than MONGODB_URI above. This is the
# only place in the app that deletes rows from the append-only audit_events /
# permission_changes ledgers (retention.pruneAnchorAligned's deleteBelowSeq).
# Leave unset to keep today's single-connection behavior (MONGODB_URI's role
# must then also grant deleteMany on those two collections). When set, the
# MONGODB_URI role should be insert+find only (plus deleteOne on ip_rules,
# updates on mutable collections, createIndex, db.stats() — see the role-split
# comment block at the top of mongoRepo.js) and MONGODB_PRUNE_URI's role should
# grant deleteMany on audit_events + permission_changes ONLY.
# MONGODB_PRUNE_URI=mongodb+srv://PRUNE_USER:PRUNE_PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# REPO: leave unset to use MONGODB_URI above. Set REPO=memory to run with NO database
# (in-memory; data is lost on restart) — handy when you don't have mongod running.
# Production deploys (Render/Vercel) must leave this unset.
# REPO=memory
# MAILER=console prints OTP/alert emails to the server console (no Gmail needed in dev).
# Production deploys must leave this unset (Gmail mailer).
# MAILER=console

# --- Field encryption (AES-256-GCM) + blind index (HMAC-SHA256) ---
# 32 raw bytes each, base64-encoded. Rotate via `node cli.js keygen`.
FIELD_ENC_KEY=BASE64_32_BYTES
BLIND_INDEX_KEY=BASE64_32_BYTES

# --- Audit ledger HMAC key (hash chain) ---
AUDIT_HMAC_KEY=BASE64_32_BYTES

# --- JWT access-token signing (Ed25519) ---
# PEM. Private = PKCS8, public = SPKI. Newlines escaped as \n on a single line.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# --- Audit anchor signing (Ed25519, separate keypair) ---
ANCHOR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
ANCHOR_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# --- Email (OTP + alerts) via Gmail app password ---
GMAIL_USER=you@example.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- HTTP server ---
PORT=8787
# HOST: NOT read from this file in practice — see warning #2 at the top. Listed
# here only for local-dev convenience (some process managers do load .env for
# HOST too); the deployed service must set it as a real env var regardless.
# Defaults to 127.0.0.1 (loopback only) when unset.
# HOST=0.0.0.0
# Comma-separated hostnames allowed in the Host header (defaults to 127.0.0.1,localhost).
# See warning #1 at the top — this MUST include your deployed hostname.
ALLOWED_HOSTS=127.0.0.1,localhost
# Set to "true" ONLY when deployed behind a proxy that sets X-Forwarded-For
# (Render/Vercel). When false (default), XFF is ignored and the socket peer IP is
# used for rate limiting, so clients cannot spoof XFF to bypass limits.
TRUST_PROXY=false
# Number of trusted proxies that APPEND to X-Forwarded-For between the client and
# this backend (Render/Vercel: usually 1). Must exactly match the real topology —
# too low leaks the proxy's own IP as "the client"; too high (or XFF shorter than
# this) fails CLOSED to the socket peer, never to a client-spoofable value.
TRUSTED_PROXY_HOPS=1
# SCHEDULER: controls the in-process daily maintenance timer (anchor both hash
# chains, verify, anchor-aligned prune) — read raw from process.env, like HOST,
# so it also bypasses the .env merge and must be set as a real service env var.
# "on" (default) for a persistent server (Render). On the serverless (Vercel)
# target the in-process timer never runs regardless of this value (a
# setInterval cannot survive between invocations) — use an external scheduler
# to run `node cli.js maintain` there instead (see render.yaml's comment).
# SCHEDULER=on
# RETENTION_DAYS: anchor-aligned prune window for the audit_events /
# permission_changes ledgers (default 7 — see lib/retention.js). Never prunes
# the live head or an anchor row itself.
# RETENTION_DAYS=7

# --- Geo/IP provider (geo-fence resolution) ---
# Without a provider, geo resolution is DISABLED and the geo-fence FAILS CLOSED:
# any user with a geoFence configured is locked out of every authenticated route
# (403 "Your location could not be verified.") until this is set.
# GEO_PROVIDER=none (default) | ip-api | geolite2
# GEO_PROVIDER=none
# ip-api: free HTTP lookup service (no API key). Override only for a mirror/self-host.
# GEO_API_URL=http://ip-api.com/json
# geolite2: local MaxMind GeoLite2 City DB file. Requires a reader library +
# .mmdb file to be wired in at deploy time (not bundled — see lib/geo.js).
# GEOLITE2_DB_PATH=C:\path\to\GeoLite2-City.mmdb

# --- Optional in-process TLS (Windows Service deployments with no reverse proxy) ---
# Leave BOTH unset (default) to serve plain HTTP, e.g. behind a platform TLS
# proxy or on a trusted LAN/VPN — this is unchanged from before. Set BOTH to
# file paths (PEM key/cert) to have the server terminate TLS itself instead;
# setting only one is a startup config error (both-or-neither). Not applicable
# on Render/Vercel — both platforms terminate TLS in front of the app.
# TLS_KEY_FILE=C:\path\to\key.pem
# TLS_CERT_FILE=C:\path\to\cert.pem

# --- Task 13: D2 device-credential upload kill-switch (informational echo) ---
# The DESKTOP CLIENT is the real enforcer of this switch (its own DEVICECRED_UPLOAD_ENABLED,
# see desktop/README.md) — this backend value has NO effect on POST /devices/claude-cred,
# which stays reachable regardless. It exists only so ops/config-dump tooling can see the
# fleet-wide intended setting alongside the client-side value. Defaults to "true"; set to
# "false" only to reflect that the fleet has been configured to stop uploading.
# DEVICECRED_UPLOAD_ENABLED=true

# --- Dev-only admin seed (REPO=memory demos ONLY — inert on the Mongo path) ---
# When both are set AND REPO=memory, context.js creates this admin on startup
# so a fresh in-memory demo has an admin account without manual signup. Never
# set these in a production (Mongo-backed) deployment — they are silently
# ignored there, but keeping real credentials out of any committed template
# is good hygiene regardless.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-now
